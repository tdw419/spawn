{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Spawn",
  "version": "0.1.0",
  "identifier": "com.tdw419.spawn",
  "build": {
    "frontendDist": "../ui",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Spawn",
        "width": 680,
        "height": 560,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../templates/geometry-os/*",
      "../templates/geometry-os/**/*",
      "../templates/ascii-world/*",
      "../templates/ascii-world/**/*"
    ]
  }
}
